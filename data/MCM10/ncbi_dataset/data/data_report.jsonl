{"geneId":"55388","symbol":"MCM10","description":"minichromosome maintenance 10 replication initiation factor","taxId":"9606","taxname":"Homo sapiens","type":"PROTEIN_CODING","orientation":"plus","commonName":"human","chromosomes":["10"],"nomenclatureAuthority":{"authority":"HGNC","identifier":"HGNC:18043"},"swissProtAccessions":["Q7L590"],"ensemblGeneIds":["ENSG00000065328"],"omimIds":["609357"],"synonyms":["CNA43","DNA43","IMD80","PRO2249"],"annotations":[{"assemblyAccession":"GCF_000001405.40","assemblyName":"GRCh38.p14","annotationName":"GCF_000001405.40-RS_2025_08","annotationReleaseDate":"2025-08-01","genomicLocations":[{"genomicAccessionVersion":"NC_000010.11","sequenceName":"10","genomicRange":{"begin":"13161558","end":"13211110","orientation":"plus"}}]},{"assemblyAccession":"GCF_009914755.1","assemblyName":"T2T-CHM13v2.0","annotationName":"GCF_009914755.1-RS_2025_08","annotationReleaseDate":"2025-08-01","genomicLocations":[{"genomicAccessionVersion":"NC_060934.1","sequenceName":"10","genomicRange":{"begin":"13176180","end":"13225648","orientation":"plus"}}]}],"transcriptCount":6,"proteinCount":6,"transcriptTypeCounts":[{"type":"PROTEIN_CODING","count":2},{"type":"PROTEIN_CODING_MODEL","count":4}],"geneGroups":[{"id":"55388","method":"NCBI Ortholog"}],"summary":[{"description":"The protein encoded by this gene is one of the highly conserved mini-chromosome maintenance proteins (MCM) that are involved in the initiation of eukaryotic genome replication. The hexameric protein complex formed by MCM proteins is a key component of the pre-replication complex (pre-RC) and it may be involved in the formation of replication forks and in the recruitment of other DNA replication related proteins. This protein can interact with MCM2 and MCM6, as well as with the origin recognition protein ORC2. It is regulated by proteolysis and phosphorylation in a cell cycle-dependent manner. Studies of a similar protein in Xenopus suggest that the chromatin binding of this protein at the onset of DNA replication is after pre-RC assembly and before origin unwinding. Alternatively spliced transcript variants encoding distinct isoforms have been identified. [provided by RefSeq, Jul 2008]"}],"geneOntology":{"assignedBy":"GOA","molecularFunctions":[{"name":"DNA replication origin binding","goId":"GO:0003688","evidenceCode":"IBA","qualifier":"enables"},{"name":"double-stranded DNA binding","goId":"GO:0003690","evidenceCode":"IEA","qualifier":"enables"},{"name":"enzyme binding","goId":"GO:0019899","evidenceCode":"IEA","qualifier":"enables"},{"name":"identical protein binding","goId":"GO:0042802","evidenceCode":"IPI","qualifier":"enables","reference":{"pmids":["17823614"]}},{"name":"protein binding","goId":"GO:0005515","evidenceCode":"IPI","qualifier":"enables","reference":{"pmids":["11095689","15232106","16189514","25416956","28514442","32296183","35271311"]}},{"name":"single-stranded DNA binding","goId":"GO:0003697","evidenceCode":"IBA","qualifier":"enables"},{"name":"single-stranded DNA binding","goId":"GO:0003697","evidenceCode":"IEA","qualifier":"enables"}],"biologicalProcesses":[{"name":"DNA damage response","goId":"GO:0006974","evidenceCode":"IMP","qualifier":"involved_in","reference":{"pmids":["24726359"]}},{"name":"DNA replication","goId":"GO:0006260","evidenceCode":"IEA","qualifier":"involved_in"},{"name":"DNA replication initiation","goId":"GO:0006270","evidenceCode":"IBA","qualifier":"involved_in"},{"name":"DNA replication initiation","goId":"GO:0006270","evidenceCode":"IEA","qualifier":"involved_in"},{"name":"DNA replication initiation","goId":"GO:0006270","evidenceCode":"IMP","qualifier":"involved_in","reference":{"pmids":["32865517"]}}],"cellularComponents":[{"name":"nuclear replication fork","goId":"GO:0043596","evidenceCode":"IBA","qualifier":"is_active_in"},{"name":"nucleolus","goId":"GO:0005730","evidenceCode":"IDA","qualifier":"located_in"},{"name":"nucleoplasm","goId":"GO:0005654","evidenceCode":"IDA","qualifier":"located_in"},{"na